############################
# Global ignores for repo  #
############################

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

############################
# Python backend           #
############################

# Virtual environments
venv/
backend/venv/

# Byte-compiled / cache
__pycache__/
backend/__pycache__/
backend/routers/__pycache__/
*.py[cod]
*$py.class

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
.tox/

# Local env / settings
.env
.env.*

############################
# Node / frontend          #
############################

node_modules/
frontend/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
frontend/dist/
dist-ssr/
*.local

############################
# Tooling / misc           #
############################

.cursor/
.turbo/
*.tsbuildinfo

